# ===========================
# App
# ===========================
NEXT_PUBLIC_APP_URL=http://localhost:5000

# ===========================
# Backend API (via Next.js proxy — tránh CORS)
# ===========================
# Browser gọi /api/proxy/... → Next.js server forward đến API_BACKEND_URL
NEXT_PUBLIC_API_URL=/api/proxy

# Địa chỉ thật của backend (dùng server-side trong proxy route, không expose ra browser)
# Backend chạy PORT=3000, không có global prefix
API_BACKEND_URL=http://localhost:3000

# ===========================
# Service Account (dùng để fetch public data từ backend, VD: pricing page)
# Điền email + password của một admin account đã được tạo trong hệ thống
# ===========================
ADMIN_SERVICE_EMAIL=lumioviet2236@gmail.com
ADMIN_SERVICE_PASSWORD=

# ===========================
# Payment (PayOS)
# ===========================
NEXT_PUBLIC_PAYOS_CLIENT_ID=a2a06396-5b5b-46a1-9d4c-dfdfd0fd7faa
